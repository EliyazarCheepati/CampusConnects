import java.util.*;

// Passenger Class
class Passenger {
    String name;
    int seatNo;

    public Passenger(String name, int seatNo) {
        this.name = name;
        this.seatNo = seatNo;
    }
}

// Bus Class
class Bus {
    int totalSeats = 10;
    boolean[] seats = new boolean[totalSeats];
    List<Passenger> passengers = new ArrayList<>();

    // Show available seats
    public void displaySeats() {
        System.out.println("\nSeat Status:");
        for (int i = 0; i < totalSeats; i++) {
            System.out.println("Seat " + (i + 1) + ": " + (seats[i] ? "Booked" : "Available"));
        }
    }

    // Book ticket
    public void bookSeat(String name, int seatNo) {
        if (seatNo < 1 || seatNo > totalSeats) {
            System.out.println("Invalid seat number!");
            return;
        }

        if (!seats[seatNo - 1]) {
            seats[seatNo - 1] = true;
            passengers.add(new Passenger(name, seatNo));
            System.out.println("Seat " + seatNo + " booked for " + name);
        } else {
            System.out.println("Seat already booked!");
        }
    }

    // Cancel ticket
    public void cancelSeat(int seatNo) {
        if (seatNo < 1 || seatNo > totalSeats) {
            System.out.println("Invalid seat number!");
            return;
        }

        if (seats[seatNo - 1]) {
            seats[seatNo - 1] = false;

            Iterator<Passenger> it = passengers.iterator();
            while (it.hasNext()) {
                Passenger p = it.next();
                if (p.seatNo == seatNo) {
                    System.out.println("Booking cancelled for " + p.name);
                    it.remove();
                    return;
                }
            }
        } else {
            System.out.println("Seat already empty!");
        }
    }

    // Display all bookings
    public void displayPassengers() {
        if (passengers.isEmpty()) {
            System.out.println("No reservations found!");
            return;
        }

        System.out.println("\nPassenger List:");
        for (Passenger p : passengers) {
            System.out.println("Name: " + p.name + " | Seat No: " + p.seatNo);
        }
    }
}

// Main Class
public class BusReservation {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Bus bus = new Bus();

        int choice;

        do {
            System.out.println("\n--- BUS RESERVATION SYSTEM ---");
            System.out.println("1. View Seats");
            System.out.println("2. Book Ticket");
            System.out.println("3. Cancel Ticket");
            System.out.println("4. View Passengers");
            System.out.println("5. Exit");
            System.out.print("Enter choice: ");

            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    bus.displaySeats();
                    break;

                case 2:
                    sc.nextLine();
                    System.out.print("Enter name: ");
                    String name = sc.nextLine();
                    System.out.print("Enter seat number: ");
                    int seatNo = sc.nextInt();
                    bus.bookSeat(name, seatNo);
                    break;

                case 3:
                    System.out.print("Enter seat number: ");
                    int cancelSeat = sc.nextInt();
                    bus.cancelSeat(cancelSeat);
                    break;

                case 4:
                    bus.displayPassengers();
                    break;

                case 5:
                    System.out.println("Thank You!");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 5);

        sc.close();
    }
}
