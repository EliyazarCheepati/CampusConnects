import java.util.*;

// Booking Class
class Booking {
    String name;
    String movie;
    int seatNo;

    public Booking(String name, String movie, int seatNo) {
        this.name = name;
        this.movie = movie;
        this.seatNo = seatNo;
    }
}

// Movie Class
class Movie {
    String movieName;
    int totalSeats = 10;
    boolean[] seats = new boolean[totalSeats];
    List<Booking> bookings = new ArrayList<>();

    public Movie(String name) {
        this.movieName = name;
    }

    // Display seats
    public void displaySeats() {
        System.out.println("\nSeats for " + movieName + ":");
        for (int i = 0; i < totalSeats; i++) {
            System.out.println("Seat " + (i + 1) + ": " + (seats[i] ? "Booked" : "Available"));
        }
    }

    // Book ticket
    public void bookTicket(String name, int seatNo) {
        if (seatNo < 1 || seatNo > totalSeats) {
            System.out.println("Invalid seat number!");
            return;
        }

        if (!seats[seatNo - 1]) {
            seats[seatNo - 1] = true;
            bookings.add(new Booking(name, movieName, seatNo));
            System.out.println("Ticket booked for " + name + " (Seat " + seatNo + ")");
        } else {
            System.out.println("Seat already booked!");
        }
    }

    // Cancel ticket
    public void cancelTicket(int seatNo) {
        if (seatNo < 1 || seatNo > totalSeats) {
            System.out.println("Invalid seat number!");
            return;
        }

        if (seats[seatNo - 1]) {
            seats[seatNo - 1] = false;

            Iterator<Booking> it = bookings.iterator();
            while (it.hasNext()) {
                Booking b = it.next();
                if (b.seatNo == seatNo) {
                    System.out.println("Cancelled booking for " + b.name);
                    it.remove();
                    return;
                }
            }
        } else {
            System.out.println("Seat already empty!");
        }
    }

    // Display bookings
    public void displayBookings() {
        if (bookings.isEmpty()) {
            System.out.println("No bookings yet!");
            return;
        }

        System.out.println("\nBookings for " + movieName + ":");
        for (Booking b : bookings) {
            System.out.println("Name: " + b.name + " | Seat: " + b.seatNo);
        }
    }
}

// Main Class
public class MovieBooking {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Movies list
        Movie m1 = new Movie("Leo");
        Movie m2 = new Movie("Jailer");
        Movie m3 = new Movie("Vikram");

        Movie selectedMovie = null;

        int choice;

        do {
            System.out.println("\n--- MOVIE TICKET BOOKING ---");
            System.out.println("1. Select Movie");
            System.out.println("2. View Seats");
            System.out.println("3. Book Ticket");
            System.out.println("4. Cancel Ticket");
            System.out.println("5. View Bookings");
            System.out.println("6. Exit");
            System.out.print("Enter choice: ");

            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    System.out.println("Available Movies:");
                    System.out.println("1. Leo\n2. Jailer\n3. Vikram");
                    int m = sc.nextInt();

                    if (m == 1) selectedMovie = m1;
                    else if (m == 2) selectedMovie = m2;
                    else if (m == 3) selectedMovie = m3;
                    else System.out.println("Invalid choice");

                    break;

                case 2:
                    if (selectedMovie != null)
                        selectedMovie.displaySeats();
                    else
                        System.out.println("Select a movie first!");
                    break;

                case 3:
                    if (selectedMovie != null) {
                        sc.nextLine();
                        System.out.print("Enter name: ");
                        String name = sc.nextLine();
                        System.out.print("Enter seat number: ");
                        int seat = sc.nextInt();
                        selectedMovie.bookTicket(name, seat);
                    } else {
                        System.out.println("Select a movie first!");
                    }
                    break;

                case 4:
                    if (selectedMovie != null) {
                        System.out.print("Enter seat number: ");
                        int cancel = sc.nextInt();
                        selectedMovie.cancelTicket(cancel);
                    } else {
                        System.out.println("Select a movie first!");
                    }
                    break;

                case 5:
                    if (selectedMovie != null)
                        selectedMovie.displayBookings();
                    else
                        System.out.println("Select a movie first!");
                    break;

                case 6:
                    System.out.println("Thank You!");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 6);

        sc.close();
    }
}
